FTP_USER=your_ftp_user
FTP_HOST=your_ftp_host
FTP_PASSWORD=your_ftp_password
FTP_PORT=21

DEPLOY_FRONTEND=perulainen.com/conteo
BASE_URL=https://perulainen.com/conteo
GA_ID=G-XXXXXXXXXX

# Legacy + shadow API publish flags
PUBLISH_LEGACY=true
PUBLISH_API_SHADOW=false

# Optional API shadow destination/credentials (fallback to FTP_* when omitted)
API_DEPLOY_PATH=perulainen.com/conteo/api
API_FTP_HOST=
API_FTP_USER=
API_FTP_PASSWORD=
API_FTP_PORT=

# Public API proxy origin (used by frontend/api/index.php)
CONTEO_API_ORIGIN_BASE=https://api-elecciones.perulainen.com/conteo/api
CONTEO_API_TIMEOUT_SECONDS=6
