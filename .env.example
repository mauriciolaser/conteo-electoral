FTP_USER=your_ftp_user
FTP_HOST=your_ftp_host
FTP_PASSWORD=your_ftp_password
FTP_PORT=21

DEPLOY_FRONTEND=perulainen.com/conteo
BASE_URL=https://perulainen.com/conteo
GA_ID=G-XXXXXXXXXX

# API publish destination/credentials
API_DEPLOY_PATH=perulainen.com/conteo/api
API_FTP_HOST=your_api_ftp_host
API_FTP_USER=your_api_ftp_user
API_FTP_PASSWORD=your_api_ftp_password
API_FTP_PORT=21

# RAW deploy destination/credentials
FTP_RAW_PATH=raw-elecciones-data
FTP_RAW_HOST=your_raw_ftp_host
FTP_RAW_USER=your_raw_ftp_user
FTP_RAW_PASSWORD=your_raw_ftp_password
FTP_RAW_PORT=21

# Public API proxy origin (used by frontend/api/index.php)
CONTEO_API_ORIGIN_BASE=https://api-elecciones.perulainen.com/conteo/api
CONTEO_API_TIMEOUT_SECONDS=6
